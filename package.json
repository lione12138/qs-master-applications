{
  "name": "gradwindow-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "Lint and format tooling for the GradWindow static frontend.",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"web/*.js\"",
    "format:check": "prettier --check \"web/*.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3"
  }
}
