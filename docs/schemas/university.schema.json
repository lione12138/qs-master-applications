    "admissionsCandidateTitle": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Admissionscandidatetitle"
    }
  },
  "required": [
    "id",
    "qsRank",
    "qsPosition",
    "rankDisplay",
    "school",
    "schoolZh",
    "country",
    "region",
    "homepageUrl",
    "officialDomains",
    "rorId",
    "rorMatchScore",
    "rorMatched",
    "admissionsUrl",
    "admissionsDiscovery",
    "datePolicy",
    "monitorEnabled",
