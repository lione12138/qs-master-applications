      "minimum": 0.0,
      "title": "Rormatchscore",
      "type": "number"
    },
    "rorMatched": {
      "title": "Rormatched",
      "type": "boolean"
    },
    "admissionsUrl": {
      "anyOf": [
        {
          "format": "uri",
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Admissionsurl"
    },
    "admissionsDiscovery": {
      "enum": [
        "curated",
        "discovered",
        "low-confidence",
        "not-found",
        "pending",
        "error"
