    "qsPosition": {
      "maximum": 200,
      "minimum": 1,
      "title": "Qsposition",
      "type": "integer"
    },
    "rankDisplay": {
      "title": "Rankdisplay",
      "type": "string"
    },
    "school": {
      "title": "School",
      "type": "string"
    },
    "schoolZh": {
      "title": "Schoolzh",
      "type": "string"
    },
    "country": {
      "title": "Country",
      "type": "string"
    },
    "region": {
      "title": "Region",
      "type": "string"
    },
    "homepageUrl": {
      "format": "uri",
      "minLength": 1,
      "title": "Homepageurl",
      "type": "string"
    },
    "officialDomains": {
      "items": {
        "type": "string"
