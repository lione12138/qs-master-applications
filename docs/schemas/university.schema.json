      "title": "Admissionsdiscovery",
      "type": "string"
    },
    "datePolicy": {
      "title": "Datepolicy",
      "type": "string"
    },
    "monitorEnabled": {
      "title": "Monitorenabled",
      "type": "boolean"
    },
    "admissionsCandidateScore": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "title": "Admissionscandidatescore"
